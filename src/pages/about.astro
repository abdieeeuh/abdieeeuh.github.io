---
import Breadcrumbs from '@/components/breadcrumbs.astro'
import PageHead from '@/components/page-head.astro'
import Layout from '@/layouts/layout.astro'
---

<Layout class="max-w-3xl">
  <PageHead slot="head" title="About" />
  <Breadcrumbs items={[{ label: 'About', icon: 'lucide:info' }]} />

  <section class="flex min-h-[40vh] items-center justify-center">
    <p class="text-center font-mono text-2xl font-semibold tracking-[0.24em] uppercase text-foreground/80 sm:text-xl">
      <span class="text-[#E0A61D]">When It's Okay to</span>
      <span class="relative top-[0.28em] inline-block rotate-180">Break</span>
      <span class="text-[#E0A61D]">the Rules</span>
    </p>
  </section>
</Layout>
